{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$ZELLIJ_SESSION_NAME\" ] && curl -s -m 2 -X POST http://127.0.0.1:47100/report -H \"X-Zellij-Session: $ZELLIJ_SESSION_NAME\" -H \"X-Zellij-Pane: $ZELLIJ_PANE_ID\" -H \"content-type: application/json\" -d \"{\\\"hook_event_name\\\":\\\"SessionStart\\\",\\\"cwd\\\":\\\"$PWD\\\"}\" >/dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:47100/report",
            "headers": {
              "X-Zellij-Session": "$ZELLIJ_SESSION_NAME",
              "X-Zellij-Pane": "$ZELLIJ_PANE_ID"
            },
            "allowedEnvVars": [
              "ZELLIJ_SESSION_NAME",
              "ZELLIJ_PANE_ID"
            ]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:47100/report",
            "headers": {
              "X-Zellij-Session": "$ZELLIJ_SESSION_NAME",
              "X-Zellij-Pane": "$ZELLIJ_PANE_ID"
            },
            "allowedEnvVars": [
              "ZELLIJ_SESSION_NAME",
              "ZELLIJ_PANE_ID"
            ]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:47100/report",
            "headers": {
              "X-Zellij-Session": "$ZELLIJ_SESSION_NAME",
              "X-Zellij-Pane": "$ZELLIJ_PANE_ID"
            },
            "allowedEnvVars": [
              "ZELLIJ_SESSION_NAME",
              "ZELLIJ_PANE_ID"
            ]
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:47100/report",
            "headers": {
              "X-Zellij-Session": "$ZELLIJ_SESSION_NAME",
              "X-Zellij-Pane": "$ZELLIJ_PANE_ID"
            },
            "allowedEnvVars": [
              "ZELLIJ_SESSION_NAME",
              "ZELLIJ_PANE_ID"
            ]
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:47100/report",
            "headers": {
              "X-Zellij-Session": "$ZELLIJ_SESSION_NAME",
              "X-Zellij-Pane": "$ZELLIJ_PANE_ID"
            },
            "allowedEnvVars": [
              "ZELLIJ_SESSION_NAME",
              "ZELLIJ_PANE_ID"
            ]
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:47100/report",
            "headers": {
              "X-Zellij-Session": "$ZELLIJ_SESSION_NAME",
              "X-Zellij-Pane": "$ZELLIJ_PANE_ID"
            },
            "allowedEnvVars": [
              "ZELLIJ_SESSION_NAME",
              "ZELLIJ_PANE_ID"
            ]
          }
        ]
      }
    ]
  }
}
